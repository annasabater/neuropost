# ── Meta (Instagram / Facebook) ──────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=

# ── Resend (email) ───────────────────────────────────────────────────────────
RESEND_API_KEY=
# Sprint 2 — emails transaccionales del módulo de planificación semanal
RESEND_FROM_EMAIL=
RESEND_REPLY_TO=

# ── Site URL (required for email links) ──────────────────────────────────────
# Dev: http://localhost:3000 · Prod: https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Sentry ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

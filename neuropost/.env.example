# =============================================================================
# NeuroPost — environment variables (example)
# Copy to .env.local or configure in Vercel project settings.
# =============================================================================

# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Cron / internal auth ─────────────────────────────────────────────────────
# Shared secret that cron endpoints require in the Authorization: Bearer header
# when they are invoked outside of Vercel's native cron runtime.
CRON_SECRET=

# ── Replicate (image generation) ─────────────────────────────────────────────
REPLICATE_API_TOKEN=

# Webhook signing secret — generate in the Replicate dashboard
# (Settings → Webhooks → "Generate signing key").
# Copy the full value including the `whsec_` prefix.
# Configure the same value in Vercel (Production + Preview).
# The webhook at /api/webhooks/replicate validates HMAC-SHA256 on every call.
REPLICATE_WEBHOOK_SECRET=

# ── Anthropic / Claude ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Meta (Instagram / Facebook) ──────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=

# ── Resend (email) ───────────────────────────────────────────────────────────
RESEND_API_KEY=

# ── Sentry ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
